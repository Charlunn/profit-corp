# =============================================================================
# Profit-Corp Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit the real .env to git.
#
# Usage:
#   cp .env.example .env
#   nano .env        # fill in tokens
#   ./setup_corp.sh  # or: docker-compose up -d
# =============================================================================

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Default recommendation: your self-hosted newapi (OpenAI-compatible).
# Fill OPENAI_BASE_URL + OPENAI_API_KEY for newapi.
OPENAI_BASE_URL=https://your-newapi-domain/v1
OPENAI_API_KEY=your_newapi_api_key_here
# Optional alternatives:
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get from: @BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your personal Telegram numeric user ID (not username).
# Find it: DM your bot, run `openclaw logs --follow`, read `from.id`.
# Or: curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
TELEGRAM_CHAT_ID=your_numeric_telegram_id_here

# ── OpenCLAW Gateway ──────────────────────────────────────────────────────────
# Strong random token for the webhook/hooks API and gateway auth. Generate with: openssl rand -hex 32
OPENCLAW_HOOKS_TOKEN=replace_with_strong_random_token

# ── Timezone ──────────────────────────────────────────────────────────────────
# IANA timezone for the daily 08:00 cron job. Examples: UTC, Asia/Shanghai, America/New_York
CORP_TIMEZONE=UTC

# ── Docker only ───────────────────────────────────────────────────────────────
# Host path for the persistent OpenCLAW state directory (sessions, cron, creds).
# Defaults to .openclaw-state in the project root.
OPENCLAW_STATE_HOST_PATH=./.openclaw-state
