# profit-corp environment variables
# Copy this file to .env and fill in the values before running docker compose up.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# OpenRouter API key (free models available at openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Telegram ──────────────────────────────────────────────────────────────────
# 1. Create a bot via @BotFather in Telegram and paste the token below.
# 2. Find your numeric user ID by messaging @userinfobot (or openclaw logs --follow).
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_OWNER_ID=123456789

# ── OpenCLAW Gateway ─────────────────────────────────────────────────────────
# Shared secret for the OpenCLAW Control UI and CLI.
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=change_me_strong_random_secret

# ── Optional: webhook hook token ─────────────────────────────────────────────
# Only needed if you enable hooks.enabled: true in openclaw.json.
OPENCLAW_HOOK_TOKEN=

# ── Timezone for cron scheduling ─────────────────────────────────────────────
# Used by setup_cron.sh.  Examples: Asia/Shanghai, America/New_York, Europe/London
CORP_TZ=UTC

# ── Docker image override ─────────────────────────────────────────────────────
# Uncomment to pin to a specific OpenCLAW version instead of :latest.
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.4.10
