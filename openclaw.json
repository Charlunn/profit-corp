{
  "agents": {
    "defaults": {
      "skipBootstrap": true,
      "contextInjection": "continuation-skip"
    },
    "list": [
      {
        "id": "ceo",
        "name": "Marcus (CEO)",
        "default": true,
        "workspace": "PROFIT_CORP_ROOT/workspaces/ceo",
        "skills": ["summarize", "github"],
        "heartbeat": {
          "every": "4h",
          "isolatedSession": true,
          "prompt": "Run company health check per HEARTBEAT.md: read shared/LEDGER.json, check treasury thresholds and agent points. Send Telegram alert if treasury < 150 or any agent point total <= 0. If all agents > 80 pts and treasury > 300, no action needed."
        }
      },
      {
        "id": "scout",
        "name": "Alex (Scout)",
        "workspace": "PROFIT_CORP_ROOT/workspaces/scout",
        "skills": ["blogwatcher", "xurl", "summarize"]
      },
      {
        "id": "cmo",
        "name": "Jordan (CMO)",
        "workspace": "PROFIT_CORP_ROOT/workspaces/cmo",
        "skills": ["github", "gh-issues", "blogwatcher"]
      },
      {
        "id": "arch",
        "name": "Sam (Architect)",
        "workspace": "PROFIT_CORP_ROOT/workspaces/arch",
        "skills": ["coding-agent", "summarize", "model-usage"]
      },
      {
        "id": "accountant",
        "name": "Taylor (Accountant)",
        "workspace": "PROFIT_CORP_ROOT/workspaces/accountant",
        "skills": ["model-usage", "healthcheck", "session-logs"]
      }
    ]
  },

  "bindings": [
    {
      "agentId": "ceo",
      "match": { "channel": "telegram" }
    },
    {
      "agentId": "ceo",
      "match": { "channel": "webchat" }
    },
    {
      "agentId": "ceo",
      "match": { "channel": "webhook" }
    }
  ],

  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": { "source": "env", "provider": "default", "id": "TELEGRAM_BOT_TOKEN" },
      "dmPolicy": "allowlist",
      "allowFrom": [],
      "streaming": "partial",
      "customCommands": [
        { "command": "help",        "description": "❓ Show all commands with usage examples" },
        { "command": "new_project", "description": "🚀 Start a new SaaS project (guided questionnaire)" },
        { "command": "status",      "description": "📊 Get company treasury & agent status" },
        { "command": "daily",       "description": "🌅 Run the full daily pipeline now" },
        { "command": "revenue",     "description": "💰 Record revenue: /revenue <amount> <source> <note>" },
        { "command": "bounty",      "description": "🎯 Grant bounty: /bounty <amount> <agent> <task>" },
        { "command": "greenlight",  "description": "✅ Greenlight a project: /greenlight <id> <reason>" },
        { "command": "veto",        "description": "❌ Veto a project: /veto <id> <reason>" },
        { "command": "audit",       "description": "📋 Trigger Accountant daily audit" },
        { "command": "archive",     "description": "🗄️ Archive completed project: /archive <project_name>" },
        { "command": "confirm",     "description": "🔐 Confirm a pending sensitive operation" },
        { "command": "cancel",      "description": "🚫 Cancel the last pending operation" }
      ]
    }
  },

  "tools": {
    "agentToAgent": {
      "enabled": true,
      "allow": ["ceo", "scout", "cmo", "arch", "accountant"]
    }
  },

  "rbac": {
    "sensitiveOps": [
      { "op": "revenue",    "threshold": 1000, "reason": "Large revenue recording" },
      { "op": "bounty",     "threshold": 500,  "reason": "Large bounty grant" },
      { "op": "archive",    "threshold": 0,    "reason": "Project archival is irreversible" },
      { "op": "fire_agent", "threshold": 0,    "reason": "Agent replacement affects org structure" },
      { "op": "governance", "threshold": 0,    "reason": "Company-wide governance changes" }
    ]
  },

  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 2,
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [60000, 120000, 300000],
      "retryOn": ["rate_limit", "overloaded", "network", "server_error"]
    },
    "sessionRetention": "48h",
    "runLog": { "maxBytes": "2mb", "keepLines": 2000 },
    "failureAlert": { "enabled": true }
  },

  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOKS_TOKEN}",
    "path": "/hooks",
    "allowedAgentIds": ["ceo", "scout", "cmo", "arch", "accountant"]
  },

  "session": {
    "dmScope": "per-channel-peer",
    "reset": {
      "mode": "daily",
      "atHour": 4,
      "idleMinutes": 240
    }
  },

  "gateway": {
    "port": 18789,
    "bind": "127.0.0.1",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_HOOKS_TOKEN}"
    },
    "channelHealthCheckMinutes": 5,
    "channelStaleEventThresholdMinutes": 30,
    "channelMaxRestartsPerHour": 10
  }
}
