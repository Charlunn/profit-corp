// ~/.openclaw/openclaw.json  (copy this to your OpenCLAW config directory)
// OpenCLAW gateway config for Profit-First SaaS Inc.
// Docs: https://docs.openclaw.ai/gateway/configuration
//
// Required environment variables (set in .env or your shell):
//   OPENROUTER_API_KEY   — OpenRouter API key
//   TELEGRAM_BOT_TOKEN   — Telegram bot token from @BotFather
//   TELEGRAM_OWNER_ID    — Your numeric Telegram user ID (from @userinfobot)
//   OPENCLAW_GATEWAY_TOKEN — Gateway shared secret (generated during setup)

{
  // ─── Agents ────────────────────────────────────────────────────────────────
  // Each agent maps to a workspace under profit-corp/workspaces/.
  // Adjust the workspace paths to match your actual profit-corp clone location.
  agents: {
    defaults: {
      // Primary model: OpenRouter free tier (change once treasury grows)
      model: {
        primary: "openrouter/deepseek/deepseek-r1-0528:free",
        fallbacks: ["openrouter/mistralai/mistral-7b-instruct:free"],
      },
      // model_interface is reserved for future Accountant-driven model upgrades.
      // Do NOT change the model fields above without Accountant authorisation.
    },
    list: [
      // ── CEO (default Telegram entry-point) ─────────────────────────────────
      // Receives all Telegram messages and orchestrates the other agents.
      {
        id: "ceo",
        workspace: "./workspaces/ceo",
        skills: ["summarize", "github"],
        groupChat: {
          mentionPatterns: ["@ceo", "ceo", "@corp"],
        },
      },
      // ── Scout ──────────────────────────────────────────────────────────────
      {
        id: "scout",
        workspace: "./workspaces/scout",
        skills: ["blogwatcher", "xurl", "summarize"],
      },
      // ── CMO ────────────────────────────────────────────────────────────────
      {
        id: "cmo",
        workspace: "./workspaces/cmo",
        skills: ["github", "gh-issues", "blogwatcher"],
      },
      // ── Architect ──────────────────────────────────────────────────────────
      {
        id: "arch",
        workspace: "./workspaces/arch",
        skills: ["coding-agent", "summarize", "model-usage"],
      },
      // ── Accountant ─────────────────────────────────────────────────────────
      {
        id: "accountant",
        workspace: "./workspaces/accountant",
        skills: ["model-usage", "healthcheck", "session-logs"],
      },
    ],
  },

  // ─── Channels ──────────────────────────────────────────────────────────────
  channels: {
    // Unified Telegram bot — one bot controls the entire company.
    // Docs: https://docs.openclaw.ai/channels/telegram
    telegram: {
      enabled: true,
      // Token is read from env; do NOT hard-code it here.
      botToken: "${TELEGRAM_BOT_TOKEN}",
      // allowlist keeps the bot private to the owner only.
      dmPolicy: "allowlist",
      allowFrom: ["${TELEGRAM_OWNER_ID}"],
      // Native command menu registered at bot startup.
      customCommands: [
        {
          command: "new_project",
          description: "Kick off a new project scan (Scout → CMO → Arch → CEO)",
        },
        {
          command: "revenue",
          description: "Report revenue: /revenue <amount_in_pts> <source>",
        },
        {
          command: "balance",
          description: "Show current treasury & agent balances",
        },
        {
          command: "daily_run",
          description: "Manually trigger the full Daily Workflow right now",
        },
        {
          command: "audit",
          description: "Run the Accountant's daily financial audit",
        },
        {
          command: "archive",
          description: "Archive the current project: /archive <project_name>",
        },
      ],
    },
  },

  // ─── Automation (Cron) ─────────────────────────────────────────────────────
  // The actual cron jobs are registered once via setup_cron.sh.
  // This section configures the failure-notification destination.
  // Docs: https://docs.openclaw.ai/automation/cron-jobs
  cron: {
    failureDestination: {
      channel: "telegram",
      to: "${TELEGRAM_OWNER_ID}",
    },
  },

  // ─── Webhooks ──────────────────────────────────────────────────────────────
  // Optional: enable inbound webhooks for external triggers (e.g. Vercel deploys).
  // Docs: https://docs.openclaw.ai/automation/webhook
  hooks: {
    enabled: false,
    token: "${OPENCLAW_HOOK_TOKEN}",
    path: "/hooks",
  },

  // ─── Skills shared across all agents ───────────────────────────────────────
  // Extra skill directories are resolved relative to the profit-corp root.
  skills: {
    load: {
      extraDirs: ["./shared/skills"],
    },
  },

  // ─── Session behaviour ─────────────────────────────────────────────────────
  session: {
    // Use per-peer DM scoping so each Telegram conversation is isolated.
    dmScope: "per-channel-peer",
    reset: {
      // Reset context daily at 04:00 UTC to start each workday fresh.
      mode: "daily",
      atHour: 4,
    },
  },

  // ─── Gateway ───────────────────────────────────────────────────────────────
  gateway: {
    // Bind to LAN so Docker port-publishing or reverse-proxy can reach it.
    bind: "lan",
    port: 18789,
    auth: {
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
    controlUi: {
      allowedOrigins: [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
      ],
    },
  },
}
