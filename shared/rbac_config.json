{
  "roles": {
    "super_admin": {
      "label": "超级管理员",
      "description": "完全控制权，可执行所有操作（包括审批其他人提交的敏感请求）",
      "permissions": ["all"],
      "users": []
    },
    "admin": {
      "label": "管理员",
      "description": "日常运营管理：发起项目、上报营收、给 Agent 打分、每日审计、查看归档",
      "permissions": [
        "new_project",
        "report_revenue",
        "view_status",
        "daily_audit",
        "score_agent",
        "view_archive"
      ],
      "users": []
    },
    "operator": {
      "label": "运营",
      "description": "基础操作：发起项目、上报营收、查看状态与归档",
      "permissions": [
        "new_project",
        "report_revenue",
        "view_status",
        "view_archive"
      ],
      "users": []
    },
    "readonly": {
      "label": "只读",
      "description": "仅可查看状态与归档，不可执行任何写操作",
      "permissions": [
        "view_status",
        "view_archive"
      ],
      "users": []
    }
  },
  "sensitive_ops": [
    "delete_project",
    "archive_project",
    "modify_finance",
    "reset_agent",
    "bounty"
  ],
  "require_approval": [
    "delete_project",
    "archive_project",
    "reset_agent"
  ]
}
